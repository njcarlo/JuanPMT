rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function isHardcodedSuperadmin() {
      return signedIn() && email() == 'njcarlo@gmail.com';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return isHardcodedSuperadmin() ||
        (hasUserDoc() && userDoc().active != false);
    }

    function isSuperadmin() {
      return isHardcodedSuperadmin() ||
        (hasUserDoc() && userDoc().role == 'superadmin');
    }

    match /pmt/{document} {
      allow read, write: if isActiveUser();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isActiveUser());
      allow create, update: if isSuperadmin();
      allow delete: if isSuperadmin() && request.auth.uid != userId;
    }
  }
}
