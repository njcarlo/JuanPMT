rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simple username/password gate lives in the app (Firestore appUsers).
    // No Firebase Auth — open read/write for the app collections.
    match /pmt/{document} {
      allow read, write: if true;
    }
    match /appUsers/{username} {
      allow read, write: if true;
    }
    // Legacy Firebase Auth user profiles (unused after simple login)
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
